{
  "manifest_version": 3,
  "name": "Stacker for WhatsApp",
  "version": "0.2.0",
  "description": "Floating sticker organization layer for WhatsApp Web.",
  "permissions": [
    "storage",
    "activeTab"
  ],
  "host_permissions": [
    "https://web.whatsapp.com/*"
  ],
  "content_scripts": [
    {
      "matches": ["https://web.whatsapp.com/*"],
      "js": ["content.js"],
      "css": ["content.css"],
      "run_at": "document_idle"
    }
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "web_accessible_resources": [
    {
      "resources": ["inject.js"],
      "matches": ["https://web.whatsapp.com/*"]
    }
  ]
}
